{
   "format_version":"1.16.0",
   "minecraft:entity":{
      "description":{
         "identifier":"eoa:faceless",
         "is_spawnable":true,
         "is_summonable":true,
         "is_experimental":false
      },
      "components":{
         "minecraft:type_family":{
            "family":[
               "monster",
               "mob",
               "enth"
            ]
         },
         "minecraft:collision_box":{
            "width":0.6,
            "height":1.9
         },
         "minecraft:health":{
            "value":20,
            "max":20
         },
         "minecraft:damage_sensor":{
            "triggers":[
               {
                  "cause":"all",
                  "deals_damage":false
               }
            ]
         },
         "minecraft:attack":{
            "damage":3
         },
         "minecraft:scale":{
            "value":1.1
         },
         "minecraft:is_shaking":{
            
         },
         "minecraft:movement":{
            "value":0.25
         },
         "minecraft:movement.basic":{
            
         },
         "minecraft:navigation.walk":{
            "can_walk":true
         },
         "minecraft:jump.static":{
            
         },
         "minecraft:physics":{
            
         },
         "minecraft:despawn":{
            "filters":{
               "all_of":[
                  {
                     "test":"distance_to_nearest_player",
                     "operator":">",
                     "value":32
                  },
                  {
                     "test":"inactivity_timer",
                     "operator":">=",
                     "value":30
                  }
               ]
            }
         },
         "minecraft:teleport":{
            "random_teleports":true,
            "max_random_teleport_time":30,
            "random_teleport_cube":[
               16,
               16,
               16
            ],
            "target_distance":8,
            "target_teleport_chance":0.05,
            "light_teleport_chance":0.05
         },
         "minecraft:behavior.nearest_attackable_target":{
            "priority":2,
            "must_see":true,
            "within_radius":25,
            "entity_types":[
               {
                  "filters":{
                     "test":"is_family",
                     "subject":"other",
                     "value":"player"
                  },
                  "max_dist":35
               }
            ]
         },
         "minecraft:behavior.melee_attack":{
            "priority":3
         },
         "minecraft:behavior.random_stroll":{
            "priority":7,
            "speed_multiplier":1
         },
         "minecraft:behavior.look_at_player":{
            "priority":8,
            "look_distance":8.0,
            "probability":0.02
         }
      }
   }
}